  },
  "devDependencies": {
    "@netlify/functions": "^2.8.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
